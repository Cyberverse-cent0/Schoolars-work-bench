# Backend Environment Variables
PORT=8081
DATABASE_URL=postgresql://postgres:password@localhost:5433/scholarforge
SESSION_SECRET=scholarforge-production-secret-key-2024

# Google OAuth
# Replace with your actual Google OAuth Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=your-actual-google-client-id.apps.googleusercontent.com

# Yahoo OAuth
# Replace with your actual Yahoo OAuth Client ID and Secret from Yahoo Developer Console
YAHOO_CLIENT_ID=your-yahoo-client-id
YAHOO_CLIENT_SECRET=your-yahoo-client-secret

# Node Environment
NODE_ENV=production

# Website URL (for redirects and links)
WEBSITE_URL=http://your-domain.com
